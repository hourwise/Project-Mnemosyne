{
  "name": "@mnemosyne/testbench",
  "version": "0.1.0",
  "private": true,
  "description": "Repeatable validation harness for Mnemosyne memory and context governance",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "bench": "tsx src/runner.ts"
  },
  "dependencies": {
    "@mnemosyne/almanac-store": "*",
    "@mnemosyne/runtime-core": "*",
    "@mnemosyne/schema": "*",
    "project-runtime-contracts": "0.4.0"
  }
}
